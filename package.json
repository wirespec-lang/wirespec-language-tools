{
  "name": "wirespec",
  "displayName": "wirespec",
  "description": "Language support for wirespec protocol description language",
  "version": "0.1.0",
  "publisher": "wirespec-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/wirespec-lang/wirespec-language-tools"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "wirespec",
        "aliases": ["wirespec", "wspec"],
        "extensions": [".wspec"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wirespec",
        "scopeName": "source.wirespec",
        "path": "./syntaxes/wirespec.tmLanguage.json"
      }
    ]
  }
}
