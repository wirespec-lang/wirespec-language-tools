{
  "name": "wirespec",
  "displayName": "wirespec-lang",
  "description": "Language support for wirespec protocol description language",
  "version": "0.1.1",
  "publisher": "wirespec-lang",
  "icon": "wirespec.png",
  "license": "Apache-2.0",
  "keywords": [
    "wirespec",
    "protocol",
    "binary",
    "lsp",
    "wspec"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wirespec-lang/wirespec-language-tools"
  },
  "engines": {
    "vscode": "^1.78.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:wirespec"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "wirespec",
        "aliases": [
          "wirespec",
          "wspec"
        ],
        "extensions": [
          ".wspec"
        ],
        "icon": {
          "light": "./fileicon.png",
          "dark": "./fileicon.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wirespec",
        "scopeName": "source.wirespec",
        "path": "./syntaxes/wirespec.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "wirespec",
        "path": "./snippets/wirespec.json"
      }
    ],
    "configuration": {
      "title": "wirespec",
      "properties": {
        "wirespec.lsp.serverPath": {
          "type": "string",
          "default": "wirespec-lsp",
          "description": "Path to the wirespec-lsp binary. Defaults to finding it on PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  }
}
